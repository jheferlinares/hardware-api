### Variables
# Local development
@baseUrl = http://localhost:3000
# Production (AWS Lambda)
# @baseUrl = https://vk6496iyqd.execute-api.us-east-1.amazonaws.com/prod/hardware
@itemId = 001

### CREATE - Create new item
POST {{baseUrl}}/hardware
Content-Type: application/json

{
  "id": "{{itemId}}",
  "name": "Laptop Dell",
  "quantity": 5,
  "location": "Office A"
}

### READ ALL - Get all items
GET {{baseUrl}}/hardware

### READ ONE - Get specific item
GET {{baseUrl}}/hardware/{{itemId}}

### UPDATE - Update item
PUT {{baseUrl}}/hardware/{{itemId}}
Content-Type: application/json

{
  "quantity": 3,
  "location": "Office B"
}

### DELETE - Delete item
DELETE {{baseUrl}}/hardware/{{itemId}}

### CREATE - Another example
POST {{baseUrl}}/hardware
Content-Type: application/json

{
  "id": "002",
  "name": "Monitor Samsung",
  "quantity": 10,
  "location": "Warehouse"
}

### Error Test - Missing required fields
POST {{baseUrl}}/hardware
Content-Type: application/json

{
  "quantity": 5
}
